# Production environment template for the Cardet Events app.
# Copy this to .env on the server (/opt/cardet-events/.env) and fill in real values.
# Never commit a real .env file.

# --- Django ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_BEHIND_TLS_PROXY=True
ALLOWED_HOSTS=qrscanner.innovedu.com,<droplet-ip>
CSRF_TRUSTED_ORIGINS=https://qrscanner.innovedu.com
SITE_BASE_URL=https://qrscanner.innovedu.com
SITE_URL=https://qrscanner.innovedu.com

# --- Database (DigitalOcean managed Postgres) ---
db_name=
db_username=
db_password=
db_host=
db_port=25060

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_CONCURRENCY=4
GUNICORN_WORKERS=3

# --- Flower (Celery monitoring UI, loopback-only) ---
FLOWER_USER=
FLOWER_PASSWORD=

# --- Stripe ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Initial superuser (only used if you wire up a createsuperuser step manually) ---
superuser=
superuser_password=
