# Local development environment template.
# Copy this to .env and fill in values. Never commit a real .env file.
# Production uses a separate template: .env.production.example (only on the server).

# --- Django ---
DJANGO_DEBUG=True
SECRET_KEY=dev-only-not-a-real-secret
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

DJANGO_SETTINGS_MODULE=event_management.settings
SITE_URL=http://127.0.0.1:8000

# --- Local Postgres (docker-compose "db" service) ---
# Setting POSTGRES_HOST is what makes settings.py use this local database instead of the
# production managed one — see the DATABASES block in settings.py.
POSTGRES_DB=event_db
POSTGRES_USER=event_user
POSTGRES_PASSWORD=devpassword
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://redis:6379/0

# --- Flower (Celery monitoring UI) ---
FLOWER_USER=admin
FLOWER_PASSWORD=devpassword

# --- pgAdmin (optional, dev compose only) ---
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# --- Stripe (test keys, optional) ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
